# Local demo defaults
MOCK_AI=true
AI_MODEL=Qwen/Qwen3-8B

# Hosted or local OpenAI-compatible runtime.
# For llama.cpp/vLLM expose /v1/chat/completions and set MOCK_AI=false.
OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:8080/v1
OPENAI_COMPATIBLE_API_KEY=replace-me

# Supabase production MVP foundation
NEXT_PUBLIC_SUPABASE_URL=https://replace-me.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_STORAGE_BUCKET=case-files

# Prisma / Supabase Postgres
DATABASE_URL=postgresql://postgres:replace-me@db.replace-me.supabase.co:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:replace-me@db.replace-me.supabase.co:5432/postgres
