generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Case {
  id                 String   @id @default(cuid())
  companyName        String
  industry           String
  annualRevenue      Float
  employeesCount     Int
  legalEntitiesCount Int
  hasDebt            Boolean
  hasCapexPlan       Boolean
  financeOwner       String
  reportsAvailableJson String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  financialInputs FinancialInput[]
  analysisResults AnalysisResult[]
  uploadedFiles   UploadedFile[]
  evidenceItems   EvidenceItem[]
}

model UploadedFile {
  id              String   @id @default(cuid())
  caseId          String
  case            Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  slot            String
  originalName    String
  mimeType        String?
  storageKey      String
  sheetNamesJson      String
  detectedColumnsJson String
  previewRowsJson     String
  status          String   @default("uploaded")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  mappingProfiles MappingProfile[]
}

model MappingProfile {
  id             String       @id @default(cuid())
  uploadedFileId String
  uploadedFile   UploadedFile @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  slot           String
  sourceSheet    String
  columnMappingJson String
  confidence     Int
  status         String       @default("draft")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model FinancialInput {
  id                  String   @id @default(cuid())
  caseId              String
  case                Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  periodName          String
  revenue             Float
  cogs                Float
  grossProfit         Float
  commercialExpenses  Float
  adminExpenses       Float
  payroll             Float
  rent                Float
  ebitda              Float
  depreciation        Float
  ebit                Float
  interestExpense     Float
  netProfit           Float
  operatingCashFlow   Float
  capex               Float
  financingCashFlow   Float
  debtRepayment       Float
  newDebt             Float
  cashStart           Float
  cashEnd             Float
  cash                Float
  accountsReceivable  Float
  inventory           Float
  fixedAssets         Float
  accountsPayable     Float
  shortTermDebt       Float
  longTermDebt        Float
  equity              Float
  avgDebtRate         Float?
  wacc                Float?
  expectedCapexRoi    Float?
  dso                 Float?
  dio                 Float?
  dpo                 Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model WorkingCapitalAging {
  id          String   @id @default(cuid())
  caseId      String
  periodName  String
  partyName   String
  partyType   String
  amount      Float
  bucket      String
  sourceRef   String
  createdAt   DateTime @default(now())
}

model DebtSchedule {
  id            String   @id @default(cuid())
  caseId        String
  lender        String
  facilityType  String
  principal     Float
  interestRate  Float?
  dueDate       DateTime?
  nextPayment   Float
  covenantNotes String?
  sourceRef     String
  createdAt     DateTime @default(now())
}

model CapexPlan {
  id              String   @id @default(cuid())
  caseId          String
  projectName     String
  amount          Float
  expectedRoi     Float?
  fundingSource   String?
  periodName      String
  managementNote  String?
  sourceRef       String
  createdAt       DateTime @default(now())
}

model SalesChannelMetric {
  id                 String   @id @default(cuid())
  caseId             String
  periodName         String
  channelName        String
  revenue            Float
  grossMargin        Float?
  discountRate       Float?
  logisticsCost      Float?
  marketplaceFee     Float?
  contributionMargin Float?
  sourceRef          String
  createdAt          DateTime @default(now())
}

model EvidenceItem {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  conclusion  String
  sourceRef   String
  formula     String?
  value       String?
  confidence  Int
  evidenceType String
  createdAt   DateTime @default(now())
}

model AnalysisResult {
  id                     String   @id @default(cuid())
  caseId                 String
  case                   Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  riskScore              Int
  riskLevel              String
  executiveSummary       String
  metricsJson                String
  redFlagsJson               String
  liquidityRisksJson         String
  operatingLeverageRisksJson String
  capexRisksJson             String
  debtRisksJson              String
  workingCapitalRisksJson    String
  financeMaturityJson        String
  hiringRecommendationJson   String
  questionsToFinanceTeamJson String
  ownerEducationBlock    String
  nextActionsJson            String
  markdownReport         String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
